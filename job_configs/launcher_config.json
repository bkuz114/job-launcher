{
  "version": "3.0",
  "settings": {
    "logs_directory": "C:\\tmp\\JobLauncherLogs",
    "theme": "default",
    "default_timeout_seconds": 30,
    "default_working_directory": "C:\\Users\\user\\your_dir"
  },
  "categories": [
    {
      "name": "Basic",
      "groups": [
        {
          "name": "Basic Commands",
          "jobs": [
            {
              "name": "Echo Hello World",
              "command": "cmd.exe /c echo Hello from Job Launcher!",
              "timeout_seconds": 10
            },
            {
              "name": "Show Current Date and Time",
              "command": "cmd.exe /c echo %DATE% %TIME%"
            },
            {
              "name": "List C:\\ Root Directory (First 20 items)",
              "command": "cmd.exe /c dir C:\\ /b | powershell.exe -Command \"$input | Select-Object -First 20\"",
              "timeout_seconds": 15
            },
            {
              "name": "Show Current Working Directory",
              "command": "cmd.exe /c echo %CD%",
              "working_directory": "C:\\Windows\\System32"
            },
            {
              "name": "Echo Multiple Lines",
              "command": "cmd.exe /c (echo Line 1 & echo Line 2 & echo Line 3 & echo Line 4 & echo Line 5)",
              "timeout_seconds": 10
            }
          ]
        }
      ]
    },
    {
      "name": "System Information",
      "groups": [
        {
          "name": "OS & Hardware",
          "jobs": [
            {
              "name": "Show Windows Version",
              "command": "cmd.exe /c ver"
            },
            {
              "name": "Show Computer Name",
              "command": "cmd.exe /c echo %COMPUTERNAME%"
            },
            {
              "name": "Show Current Username",
              "command": "cmd.exe /c echo %USERNAME%"
            },
            {
              "name": "Show Environment Variables (PATH sample)",
              "command": "cmd.exe /c echo %PATH%"
            },
            {
              "name": "Show Processor Name",
              "command": "cmd.exe /c echo %PROCESSOR_IDENTIFIER%"
            },
            {
              "name": "Show Number of Processors",
              "command": "cmd.exe /c echo %NUMBER_OF_PROCESSORS%"
            }
          ]
        },
        {
          "name": "Disk & Memory",
          "jobs": [
            {
              "name": "Show C: Drive Free Space (GB)",
              "command": "cmd.exe /c dir C:\\"
            },
            {
              "name": "Show All Drives",
              "command": "cmd.exe /c wmic logicaldisk get name, size, freespace"
            }
          ]
        },
        {
          "name": "Process & Services",
          "jobs": [
            {
              "name": "List Running Processes (First 10)",
              "command": "cmd.exe /c tasklist | powershell -Command \"$input | Select-Object -First 12\"",
              "timeout_seconds": 10
            },
            {
              "name": "Show Chrome Processes Count",
              "command": "cmd.exe /c tasklist /FI \"IMAGENAME eq chrome.exe\" | find /c /v \"\""
            },
            {
              "name": "Show Running Services",
              "command": "cmd.exe /c net start | findstr /v \"The following\" | findstr /v \"^\\.$\" | findstr /v \"^$\""
            }
          ]
        }
      ]
    },
    {
      "name": "Network",
      "groups": [
        {
          "name": "Connection Info",
          "jobs": [
            {
              "name": "Show IP Configuration",
              "command": "cmd.exe /c ipconfig"
            },
            {
              "name": "Show IP Address Only",
              "command": "cmd.exe /c ipconfig | findstr IPv4"
            },
            {
              "name": "Show Wireless Networks",
              "command": "cmd.exe /c netsh wlan show profiles"
            },
            {
              "name": "Show ARP Table",
              "command": "cmd.exe /c arp -a"
            }
          ]
        },
        {
          "name": "DNS & Tests",
          "jobs": [
            {
              "name": "Ping Localhost",
              "command": "cmd.exe /c ping 127.0.0.1 -n 4",
              "timeout_seconds": 10
            },
            {
              "name": "Ping Google DNS",
              "command": "cmd.exe /c ping 8.8.8.8 -n 4",
              "timeout_seconds": 10
            },
            {
              "name": "DNS Lookup (google.com)",
              "command": "cmd.exe /c nslookup google.com",
              "timeout_seconds": 15
            }
          ]
        }
      ]
    },
    {
      "name": "File & Directory",
      "groups": [
        {
          "name": "Directory Info",
          "jobs": [
            {
              "name": "Show Temp Directory Path",
              "command": "cmd.exe /c echo %TEMP%"
            },
            {
              "name": "List Temp Files (First 10)",
              "command": "cmd.exe /c dir %TEMP% /b"
            }
          ]
        }
      ]
    },
    {
      "name": "Time & Display",
      "groups": [
        {
          "name": "Date & Time",
          "jobs": [
            {
              "name": "Show Current Date",
              "command": "cmd.exe /c date /t"
            },
            {
              "name": "Show Current Time",
              "command": "cmd.exe /c time /t"
            },
            {
              "name": "Show Timezone",
              "command": "cmd.exe /c tzutil /g"
            }
          ]
        },
        {
          "name": "Power & Display",
          "jobs": [
            {
              "name": "Show Active Power Plan",
              "command": "cmd.exe /c powercfg /getactivescheme"
            }
          ]
        }
      ]
    },
    {
      "name": "Detached Jobs",
      "groups": [
        {
          "name": "Applications",
          "jobs": [
            {
              "name": "Notepad",
              "command": "notepad.exe",
              "detached": true
            },
            {
              "name": "Notepad - Path with Spaces",
              "command": "notepad.exe \"C:\\Users\\user\\test folder\\testfile.txt\"",
              "detached": true
            },
            {
              "name": "Calculator",
              "command": "calc.exe",
              "detached": true
            }
          ]
        },
        {
          "name": "Console Output (Detached)",
          "jobs": [
            {
              "name": "Echo Hello (cmd)",
              "command": "cmd.exe /c echo Hello from detached job",
              "detached": true
            },
            {
              "name": "PowerShell Write-Host",
              "command": "powershell.exe -Command \"Write-Host \"Hello from PowerShell\"\"",
              "detached": true
            },
            {
              "name": "List Directory (cmd)",
              "command": "cmd.exe /c dir C:\\",
              "detached": true
            }
          ]
        }
      ]
    },
    {
      "name": "Testing",
      "groups": [
        {
          "name": "Timeout & Kill",
          "jobs": [
            {
              "name": "Countdown 30s (Test Completion)",
              "command": "cmd.exe /c timeout /t 30 /nobreak",
              "timeout_seconds": 60
            },
            {
              "name": "Infinite Loop (Test Kill Button)",
              "command": "cmd.exe /c ping -t 127.0.0.1",
              "timeout_seconds": 300
            },
            {
              "name": "Slow Job (Test Timeout - 25s)",
              "command": "powershell.exe -Command \"1..25 | ForEach-Object { Write-Host 'Step' $_; Start-Sleep -Seconds 1 }; Write-Host 'Done'\"",
              "timeout_seconds": 10
            },
            {
              "name": "Very Slow Job (Test Kill - 60s)",
              "command": "powershell.exe -Command \"1..60 | ForEach-Object { Write-Host 'Waiting...' $_; Start-Sleep -Seconds 1 }; Write-Host 'Finished'\"",
              "timeout_seconds": 60
            },
            {
              "name": "Test Error Output (stderr only)",
              "command": "powershell.exe -Command \"Write-Error 'This is a test error message (harmless)'; Write-Host 'But stdout still works'\"",
              "timeout_seconds": 10
            },
            {
              "name": "Success Then Error Exit Code",
              "command": "cmd.exe /c echo This command will exit with code 1 & exit 1",
              "timeout_seconds": 10
            }
          ]
        },
        {
          "name": "Error Handling",
          "jobs": [
            {
              "name": "Missing Executable (Triggers Hint)",
              "command": "imaginary.exe"
            },
            {
              "name": "Missing Working Directory (Fast Fail)",
              "command": "cmd.exe /c echo This should not run",
              "working_directory": "C:\\ThisDirectoryDoesNotExist_ABCDEF"
            },
            {
              "name": "Non-zero Exit Code",
              "command": "cmd.exe /c exit 1"
            }
          ]
        },
        {
          "name": "Detached Tests",
          "jobs": [
            {
              "name": "Detached Notepad",
              "command": "notepad.exe",
              "detached": true
            },
            {
              "name": "Detached Missing Executable",
              "command": "nonexistent.exe",
              "detached": true
            }
          ]
        }
      ]
    }
  ]
}
